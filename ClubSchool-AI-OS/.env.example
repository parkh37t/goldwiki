# ClubSchool AI OS 콘솔 서버 환경변수 (.env 로 복사해 사용; .env 는 커밋 금지)

# 필수: 서버사이드 Anthropic 프록시용 키 (브라우저에 노출되지 않음)
ANTHROPIC_API_KEY=sk-ant-여기에_키

# 선택
PORT=8000                      # 바인딩 포트 (클라우드는 플랫폼이 주입)
CS_MODEL=claude-opus-4-8       # 기본 모델 (claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001)
CS_MAX_TOKENS_CAP=8192         # 응답 토큰 상한
