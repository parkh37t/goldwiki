# ClubSchool AI OS 콘솔 서버 환경변수 (.env 로 복사해 사용; .env 는 커밋 금지)

# 필수: 서버사이드 Anthropic 프록시용 키 (브라우저에 노출되지 않음)
ANTHROPIC_API_KEY=sk-ant-여기에_키

# 선택
PORT=8000                      # 바인딩 포트 (클라우드는 플랫폼이 주입)
CS_MODEL=claude-opus-4-8       # 기본 모델 (claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001)
CS_MAX_TOKENS_CAP=8192         # 응답 토큰 상한

# ----- Supabase (인증 + 영속화 + 자동학습 벡터) — 선택 -----
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=eyJ...                 # 공개 anon 키 (콘솔에 노출, /api/config로 전달)
SUPABASE_SERVICE_ROLE=eyJ...             # 서버 전용 (임베딩 적재/RAG). 절대 공개 금지

# ----- 자동 학습(RAG) 임베딩 제공자 — 선택 (둘 중 하나) -----
OPENAI_API_KEY=sk-...                    # text-embedding-3-small (1536차원, schema 기본)
# VOYAGE_API_KEY=pa-...                  # voyage-3 사용 시 (schema 벡터 차원 조정 필요)
CS_EMBED_MODEL=text-embedding-3-small
CS_EMBED_DIM=1536
